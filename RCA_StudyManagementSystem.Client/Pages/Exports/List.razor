@page "/exports/list"
@page "/exports/list/{StudyId:guid}"

@using Blazored.LocalStorage
@using RCA_StudyManagementSystem.Client.Utilities
@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using RCA_StudyManagementSystem.Shared.ViewModels
@using MudBlazor
@using System.Linq

@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject PathReportData PathReportData
@inject PatientData PatientData
@inject StudyData StudyData
@inject GridStateView<PathReportView> PathGridStateView
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject GenerateBatchNumber GenerateBatchNumber
@inject BatchData BatchData
@inject PathReportExportData PathReportExportData




@implements IDisposable

@rendermode InteractiveWebAssembly


<MudPaper Class="d-flex pa-2 rca-case-header">
    <h3 class="mt-2 mr-5"></h3>
    <MudItem xs="4" sm="3" md="2">
        <MudSelect id="studySelect" T="Study" @bind-Value="studySelectValue" @bind-Text="studySelectText" Typo="Typo.subtitle1" Margin="Margin.Dense"
                   Label="Study" HelperText="" Placeholder="Select Study" Variant="Variant.Outlined" Dense="true"
                   SelectedValuesChanged="@((value) => OnStudySelectChanged(value.First<Study>()))"
                   aria-hidden="false">
            @foreach (var option in StudyList)
            {
                <MudSelectItem T="Study" Value="@option">@option.Prefix</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <style>
        .rca-case-header {
            background-color: @StudyColor;
        }
    </style>
    <MudSpacer />
    <div class="mt-3">
        @if(IsLoaded)
        {
            <MudButton Class="ml-1" Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small" OnClick="() => RecheckEligibility(StudyId)">Recheck Eligibility</MudButton>

        }
        @if (StudyId == Guid.Parse("889CD103-A5BA-48EA-1168-08DDD04D0C1E"))  // Breast study
        {
            <MudButton Class="ml-1" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" OnClick="() => OnGenerateReport(StudyId)">Generate Report</MudButton>
        }
        <MudButton Class="ml-1" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="() => OnExport(StudyId)">Export Path Reports</MudButton>
    </div>
</MudPaper>
<br />
@if (IsExported)
{

    Snackbar.Add("Path Reports have been exported.", Severity.Success);
    IsExported = false;

}
@if (StudyId != Guid.Empty)
{
    <div class="@(ShowFields ? "" : "d-none")">
        <MudDataGrid T="PathReportView" @ref="pathGrid" Items="@_displayItems" SortMode="SortMode.Single" Filterable="true"
                     ColumnResizeMode="ResizeMode.Column"
                     QuickFilter="@_quickFilter" Dense
                     FilterDefinitions="@PathGridStateView.FilterDefinitions"
                     SortDefinitions="@PathGridStateView.SortDefinitions"
                     CurrentPage="@PathGridStateView.CurrentPage"
                     CurrentPageChanged=@((currentPage) => OnCurrentPageChanged(currentPage))
                     FilterMode="DataGridFilterMode.ColumnFilterRow" AllowUnsorted="false" FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Exports by Path Report</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true" TextUpdateSuppression="false"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable="true"></MudTextField>
            </ToolBarContent>
            <Columns>

                <PropertyColumn Property="x => x.CaseNumber" Title="Case Number" Filterable="false" />
                <PropertyColumn Property="x => x.LastName" Title="Last Name" Filterable="false" />
                <PropertyColumn Property="x => x.FirstName" Title="First Name" Filterable="false" />
                <PropertyColumn Property="x => x.DateOfBirth" Title="Date of Birth" Filterable="false" />

                <PropertyColumn Property="x => x.ExportStatus" Title="Export Status" Filterable="false" />
                <PropertyColumn Property="x => x.SocialSecurityNumber" Title="Social Security Number" Hidden Filterable="false" />
                <PropertyColumn Property="x => x.SubmittingHospitalPathReportNumber" Title="Sub. Hosp. Path Report Number" Hidden Filterable="false" />
                <PropertyColumn Property="x => x.SubmittingHospital" Title="Submitting Hospital" Hidden Filterable="false" />
                <PropertyColumn Property="x => x.HospShortName" Title="Hospital Short Name" Hidden Filterable="false" />
                <PropertyColumn Property="x => x.DisplayName" Title="Display Name" Hidden Filterable="false" />
                <TemplateColumn Tag="@("ExportDate")" Title="Export Date" SortBy="x => x.RcaExportDate" Context="dateContext" Sortable="true">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@dateContext.Item.RcaExportDate?.ToShortDateString()</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Age of Path" SortBy="x => x.MaxAgeDiff" Context="ageContext" Sortable="true">
                    <CellTemplate>
                        @if (ageContext.Item.MaxAgeDiff > 0)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">@ageContext.Item.MaxAgeDiff</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">N/A</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.IsOnHold" Title="On Hold" Sortable="true" SortBy="@_sortByHold" HeaderStyle="width: 15em;">
                    <CellTemplate>
                        <MudCheckBox T="bool" @bind-Value="context.Item.IsOnHold" ReadOnly="true" />
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn HeaderText="Actions">
                    <CellTemplate>
                        @*                 <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.ContactPage" OnClick=@(() => ViewItem(context.Item)) Variant="Variant.Text" Color="Color.Primary">Edit</MudIconButton>
 *@                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.ContactPage" OnClick=@(() => ViewItem(context.Item.Patient, context.Item)) Variant="Variant.Text" Color="Color.Primary">View</MudIconButton>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" Href="@($"/cases/edit/{context.Item.PatientId}/CurrentExports")" Variant="Variant.Text" Color="Color.Primary">Edit</MudIconButton>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="PathReportView" />
            </PagerContent>
        </MudDataGrid>
        <br />
    </div>

    <div class="@(ShowEligibility ? "" : "d-none")">
        <MudDataGrid T="PathReportView" @ref="eligGrid" Items="@_eligItems" SortMode="SortMode.Single" Filterable="true"
                     ColumnResizeMode="ResizeMode.Column"
                     QuickFilter="@_quickFilter" Dense
                     FilterDefinitions="@PathGridStateView.FilterDefinitions"
                     SortDefinitions="@PathGridStateView.SortDefinitions"
                     CurrentPage="@PathGridStateView.CurrentPage"
                     CurrentPageChanged=@((currentPage) => OnCurrentPageChanged(currentPage))
                     FilterMode="DataGridFilterMode.ColumnFilterRow" AllowUnsorted="false" FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Eligibility Report</MudText>
                <MudSpacer />
@*                 <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true" TextUpdateSuppression="false"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable="true"></MudTextField> *@
            </ToolBarContent>
            <Columns>

                <PropertyColumn Property="x => x.CaseNumber" Title="Case Number" Filterable="false" />
                <PropertyColumn Property="x => x.LastName" Title="Last Name" Filterable="false" />
                <TemplateColumn Title="Min Age" Context="minAgeContext" Sortable="true">
                    <CellTemplate>
                        @if (!minAgeContext.Item.IsMinAgeValid )
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Max Age" Context="maxAgeContext" Sortable="true">
                    <CellTemplate>
                        @if (!maxAgeContext.Item.IsMaxAgeValid)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Path Min Age" Context="pathMinAgeContext" Sortable="true">
                    <CellTemplate>
                        @if (!pathMinAgeContext.Item.IsPathMinAgeValid)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Path Max Age" Context="pathMaxAgeContext" Sortable="true">
                    <CellTemplate>
                        @if (!pathMaxAgeContext.Item.IsPathMaxAgeValid)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="County" Context="countyContext" Sortable="true">
                    <CellTemplate>
                        @if (!countyContext.Item.IsCountyValid)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>    
                <TemplateColumn Title="Case Match" Context="caseMatchContext" Sortable="true">
                    <HeaderTemplate>
                        Case Match<MudTooltip Placement="Placement.Right" Text="Primary" Color="Color.Info">
                            @* ChildContent is the element that triggers the tooltip on hover *@
                            <ChildContent>
                                <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" Class="mt-n2" />
                            </ChildContent>

                            @* TooltipContent is the custom content displayed inside the tooltip *@
                            <TooltipContent>
                                <MudText Typo="Typo.h6">Case Match Info</MudText>
                                <MudText Typo="Typo.body2" Style="text-align: left">
                                    The Case Match checks to make sure that this case does not match another case in any active study in this system.
                                </MudText>
                                <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Color="Color.Warning" />
                            </TooltipContent>
                        </MudTooltip>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (!caseMatchContext.Item.IsCaseMatchValid)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="DNC Match" Context="dncContext" Sortable="true">
                    <CellTemplate>
                        @if (!dncContext.Item.IsDNCValid)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">Failed</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Typo="Typo.body2">Passed</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="PathReportView" />
            </PagerContent>
        </MudDataGrid>
        <br />
    </div>
}
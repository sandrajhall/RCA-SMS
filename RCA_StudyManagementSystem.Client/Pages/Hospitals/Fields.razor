@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using System.ComponentModel.DataAnnotations
@using MudBlazor
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json;
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IConfiguration Configuration
@inject ReimbursementEntityData ReimbursementEntityData
@inject UserData UserData




@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@* This style does not get picked up in the css file, so it has to go here.
 *@
<style>
    .mud-toolbar {
        --mud-internal-toolbar-height: 15px !important;
        z-index: 10000 !important;
    }

    .mud-popover {
        z-index: 20000 !important;
    }

    .mud-input > textarea.mud-input-root.mud-input-root-margin-dense {
        padding-left: 8px !important;
    }

    .mud-input {
        background-color: white !important;
    }

    .mud-input-control.mud-input-control-margin-normal.mud-input-outlined-with-label {
        font: caption;
        font-weight: bolder !important;
    }

    .mud-grid {
        background-color: #dadfe096 !important;
        padding-right: 24px;
        padding-bottom: 24px;
    }

    .mud-checkbox-false {
        background-color: white !important;
    }

</style>

<NavigationLock OnBeforeInternalNavigation="HandleInternalNavigation" ConfirmExternalNavigation="EditContext.IsModified()" />


<br />
<br />
<MudContainer>
    <MudGrid>

        <MudItem xs="12" sm="4" md="6" Class="my-n3">
            <MudTextField Label="Short Name" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.HospitalShortName" Margin="Margin.Normal"
                          For="@(() => Hospital.HospitalShortName)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="3" Class="my-n3">
            <MudTextField Label="Hospital Code" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.HospitalCode" Margin="Margin.Normal"
                          For="@(() => Hospital.HospitalCode)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="3" Class="my-n3" />
        <MudItem xs="12" sm="4" md="9" Class="my-n3">
            <MudTextField Label="Full Name" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.HospitalName" Margin="Margin.Normal"
                          For="@(() => Hospital.HospitalName)"></MudTextField>
        </MudItem>


        <MudItem xs="12" sm="6" md="6" Class="mt-n3">
            <MudAutocomplete T="GeoapifySuggestion" Label="Search Address" Clearable Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                             SearchFunc="@Search" Variant="Variant.Outlined" Margin="Margin.Normal"
                             ShowProgressIndicator="true" ProgressIndicatorColor="Color.Inherit"
                             ToStringFunc="@((GeoapifySuggestion e)=> e==null?null : $"{e.FormattedAddress}")"
                             Value="@SelectedValue" ValueChanged="@SelectAddress">
                <ItemDisabledTemplate>
                    <MudText>Not available: @context.ToString()</MudText>
                </ItemDisabledTemplate>
            </MudAutocomplete>
        </MudItem>
        <MudItem xs="12" sm="8" md="6" Class="my-n3" />

        <MudItem xs="12" sm="8" md="6" Class="my-n3">
            <MudTextField Label="Address 1" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.Address1" Margin="Margin.Normal"
                          For="@(() => Hospital.Address1)"></MudTextField>
        </MudItem>

        <MudItem xs="12" sm="8" md="6" Class="my-n3">
            <MudTextField Label="Address 2" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.Address2" Margin="Margin.Normal"
                          For="@(() => Hospital.Address2)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="City" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.City" Margin="Margin.Normal"
                          For="@(() => Hospital.City)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="State" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.State" Margin="Margin.Normal"
                          For="@(() => Hospital.State)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="Zip Code" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.ZipCode" Margin="Margin.Normal"
                          For="@(() => Hospital.ZipCode)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="County" Variant="Variant.Outlined"
                          @bind-Value="@Hospital.County" Margin="Margin.Normal"
                          For="@(() => Hospital.County)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="4" Class="my-n3">
            <MudTextField Label="Phone Number" @bind-Value="Hospital.PhoneNumber"
                          Variant="Variant.Outlined"
                          Mask="@(new PatternMask("000-000-0000"))" Margin="Margin.Normal"
                          For="@(() => Hospital.PhoneNumber)" ></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="4" Class="my-n3">
            <MudTextField Label="FAX Number" @bind-Value="Hospital.FaxNumber"
                          Variant="Variant.Outlined"
                          Mask="@(new PatternMask("000-000-0000"))" Margin="Margin.Normal"
                          For="@(() => Hospital.FaxNumber)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="my-n3"/>

        <MudItem xs="12" sm="6" md="4" Class="my-n3">
            <MudSelect T="Guid?" @bind-Value="Hospital.ReimbursementEntityId" ToStringFunc="@((Guid? id) => GetDisplayText(id))"
                       Label="Reimbursement Entity" HelperText="" Placeholder="Select Entity"
                       Variant="Variant.Outlined" Margin="Margin.Normal"
                       For="@(() => Hospital.ReimbursementEntityId)">
                @foreach (var option in reimbursementEntities)
                {
                    <MudSelectItem T="Guid?" Value="@option.ReimbursementEntityId">@option.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3"/>
            <MudItem xs="12" sm="4" md="6" Class="my-n3">
                <MudTextField AutoGrow Label="Comments" Variant="Variant.Outlined"
                          Style="min-height: 55px !important"
                          @bind-Value="@Hospital.HospitalComments" Margin="Margin.Normal"
                          For="@(() => Hospital.HospitalComments)"></MudTextField>
        </MudItem>
    </MudGrid>
            <MudText Color="Color.Success">Hospital record last modified on @modDate by @modUser.</MudText>

</MudContainer>

@* <pre>
    @(JsonSerializer.Serialize(Hospital, new JsonSerializerOptions { WriteIndented = true }))
</pre> *@

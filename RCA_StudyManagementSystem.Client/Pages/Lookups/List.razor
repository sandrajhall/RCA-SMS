@attribute [Authorize]
@page "/app/lookups/list"

@using Microsoft.AspNetCore.Authorization
@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using MudBlazor
@using System.Linq

@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject LookupData LookupData
@inject HistologyData HistologyData
@inject IJSRuntime JSRuntime


@rendermode InteractiveAuto

<style>

    .mud-datagrid-modified-row {
        background-color: #ffe0b2; /* Light orange */
    }
</style>
<NavigationLock OnBeforeInternalNavigation="HandleInternalNavigation" ConfirmExternalNavigation="HasChanges" />


<MudPaper Class="d-flex pa-2 rca-case-header">
    <MudText Typo="Typo.h6">Lookups</MudText>


    <MudSpacer />
    <div class="col-2">
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Color="Color.Info" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnSubmitAsync">Save</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Cancel" Color="Color.Warning" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnCancel">Cancel</MudButton>

    </div>
</MudPaper>
<br />

<MudDataGrid T="Lookup" Items="@Lookups" SortMode="SortMode.Single" Filterable="true" QuickFilter="@_quickFilter" Dense Virtualize
             ReadOnly="false" EditMode="DataGridEditMode.Cell" EditTrigger="@DataGridEditTrigger.Manual" RowClassFunc="@GetRowClass" CommittedItemChanges="HandleCommittedChanges"
             FilterMode="DataGridFilterMode.ColumnFilterRow" AllowUnsorted="false" FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive">
    <ToolBarContent>
        <MudText Typo="Typo.h6"></MudText>
        <MudItem xs="12" sm="12" md="8" Class="d-flex justify-start mr-3 mt-n2">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="AddNewLookup">Add Lookup</MudButton>
        </MudItem>
        <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true" TextUpdateSuppression="false"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable="true"></MudTextField>
    </ToolBarContent>
    <ColGroup>
        <col style="width: 10%;" />
        <col style="width: 10%;" />
        <col style="width: 40%;" />
        <col style="width: 20%;" />
        <col style="width: 20%;" />
        <col />
    </ColGroup>
    <Columns>
        <PropertyColumn Property="x => x.SortOrder" Title="Sort Order" Filterable="false" Sortable="true" Editable>
            <EditTemplate Context="orderContext">
                <MudTextField T="int" class="mud-text-field-input" Value="orderContext.Item.SortOrder" ValueChanged="(newValue) => OnSortOrderChanged(newValue, orderContext.Item)"
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense"
                              For="@(() => orderContext.Item.SortOrder)" Style="border: 1px solid #ccc; border-radius: 4px;"></MudTextField>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.LookupCode" Title="Code" Filterable="false" Sortable="true" Editable>
            <EditTemplate Context="codeContext">
                <MudTextField T="string" class="mud-text-field-input" Value="codeContext.Item.LookupCode" ValueChanged="(newValue) => OnCodeChanged(newValue, codeContext.Item)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              For="@(() => codeContext.Item.LookupCode)" Style="border: 1px solid #ccc; border-radius: 4px;"></MudTextField>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.LookupName" Title="Name" Filterable="false" Sortable="true" Editable>
            <EditTemplate Context="nameContext">
                <MudTextField T="string" class="mud-text-field-input" Value="nameContext.Item.LookupName" ValueChanged="(newValue) => OnLookupNameChanged(newValue, nameContext.Item)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              For="@(() => nameContext.Item.LookupName)" Style="border: 1px solid #ccc; border-radius: 4px;"></MudTextField>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.LookupType" Title="Type" Filterable="true" Sortable="true" Editable>
            <EditTemplate Context="typeContext">
                <MudTextField T="string" class="mud-text-field-input" Value="typeContext.Item.LookupType" ValueChanged="(newValue) => OnLookupTypeChanged(newValue, typeContext.Item)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              For="@(() => typeContext.Item.LookupType)" Style="border: 1px solid #ccc; border-radius: 4px;"></MudTextField>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Comments" Title="Comments" Filterable="false" Editable>
            <EditTemplate Context="commentContext">
                <MudTextField T="string" class="mud-text-field-input" Value="commentContext.Item.Comments" ValueChanged="(newValue) => OnCommentsChanged(newValue, commentContext.Item)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              For="@(() => commentContext.Item.Comments)" Style="border: 1px solid #ccc; border-radius: 4px;"></MudTextField>
            </EditTemplate>
        </PropertyColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Lookup" />
    </PagerContent>
</MudDataGrid>
@* <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"  OnClick="OnImport">Import Lookups</MudButton> *@


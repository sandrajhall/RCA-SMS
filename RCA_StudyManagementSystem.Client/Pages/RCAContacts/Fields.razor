@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using System.ComponentModel.DataAnnotations
@using MudBlazor
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json;
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IConfiguration Configuration
@inject UserData UserData




@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@* This style does not get picked up in the css file, so it has to go here.
 *@
<style>
    .mud-toolbar {
        --mud-internal-toolbar-height: 15px !important;
        z-index: 10000 !important;
    }

    .mud-popover {
        z-index: 20000 !important;
    }

    .mud-input > textarea.mud-input-root.mud-input-root-margin-dense {
        padding-left: 8px !important;
    }

    .mud-input {
        background-color: white !important;
    }

    .mud-input-control.mud-input-control-margin-normal.mud-input-outlined-with-label {
        font: caption;
        font-weight: bolder !important;
    }

    .mud-grid {
        background-color: #dadfe096 !important;
        padding-right: 24px;
        padding-bottom: 24px;
    }

    .mud-checkbox-false {
        background-color: white !important;
    }

</style>

<NavigationLock OnBeforeInternalNavigation="HandleInternalNavigation" ConfirmExternalNavigation="EditContext.IsModified()" />


<br />
<br />
<MudContainer>
    <MudGrid>

        <MudItem xs="12" sm="4" md="3" Class="my-n3">
            <MudTextField Label="First Name" Variant="Variant.Outlined"
                          @bind-Value="@RCAContact.FirstName" Margin="Margin.Normal"
                          For="@(() => RCAContact.FirstName)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="3" Class="my-n3">
            <MudTextField Label="Last Name" Variant="Variant.Outlined"
                          @bind-Value="@RCAContact.LastName" Margin="Margin.Normal"
                          For="@(() => RCAContact.LastName)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="2" Class="my-n3">
            <MudTextField Label="Credentials" Variant="Variant.Outlined"
                          @bind-Value="@RCAContact.Credentials" Margin="Margin.Normal"
                          For="@(() => RCAContact.Credentials)"></MudTextField>
        </MudItem>

        <MudItem xs="12" sm="4" md="4" Class="my-n3" />
        <MudItem xs="12" sm="6" md="4" Class="my-n3">
            <MudTextField Label="Title" Variant="Variant.Outlined"
                          @bind-Value="@RCAContact.Title" Margin="Margin.Normal"
                          For="@(() => RCAContact.Title)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="8" Class="my-n3" />
        <MudItem xs="12" sm="6" md="4" Class="my-n3">
            <MudTextField Label="Email" Variant="Variant.Outlined"
                          @bind-Value="@RCAContact.Email" Margin="Margin.Normal"
                          For="@(() => RCAContact.Email)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="8" Class="my-n3" />
        <MudItem xs="12" sm="4" md="4" Class="my-n3">
            <MudTextField Label="Phone Number" @bind-Value="RCAContact.PhoneNumber"
                          Variant="Variant.Outlined"
                          Mask="@(new PatternMask("000-000-0000"))" Margin="Margin.Normal"
                          For="@(() => RCAContact.PhoneNumber)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="2" Class="my-n3">
            <MudTextField Label="Extension" Variant="Variant.Outlined"
                          @bind-Value="@RCAContact.PhoneExtension" Margin="Margin.Normal"
                          For="@(() => RCAContact.PhoneExtension)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3" />
        <MudItem xs="12" sm="4" md="6" Class="my-n3">
            <MudTextField AutoGrow Label="Comments" Variant="Variant.Outlined"
                          Style="min-height: 55px !important"
                          @bind-Value="@RCAContact.Comments" Margin="Margin.Normal"
                          For="@(() => RCAContact.Comments)"></MudTextField>
        </MudItem>
    </MudGrid>
    <MudText Color="Color.Success">RCA Contact record last modified on @modDate by @modUser.</MudText>

</MudContainer>


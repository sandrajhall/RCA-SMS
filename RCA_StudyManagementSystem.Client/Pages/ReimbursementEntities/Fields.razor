@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using System.ComponentModel.DataAnnotations
@using MudBlazor
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json;
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IConfiguration Configuration
@inject RCAContactData RCAContactData




@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@* This style does not get picked up in the css file, so it has to go here.
 *@
<style>
    .mud-toolbar {
        --mud-internal-toolbar-height: 15px !important;
        z-index: 10000 !important;
    }

    .mud-popover {
        z-index: 20000 !important;
    }

    .mud-input > textarea.mud-input-root.mud-input-root-margin-dense {
        padding-left: 8px !important;
    }

    .mud-input {
        background-color: white !important;
    }

    .mud-input-control.mud-input-control-margin-normal.mud-input-outlined-with-label {
        font: caption;
        font-weight: bolder !important;
    }

    .mud-grid {
        background-color: #dadfe096 !important;
        padding-right: 24px;
        padding-bottom: 24px;
    }

    .mud-checkbox-false {
        background-color: white !important;
    }

</style>

<NavigationLock OnBeforeInternalNavigation="HandleInternalNavigation" ConfirmExternalNavigation="EditContext.IsModified()" />


<br />
<br />
<MudContainer>
    <MudGrid>

        <MudItem xs="12" sm="4" md="6" Class="my-n3">
            <MudTextField Label="Name" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.Name" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.Name)"></MudTextField>
        </MudItem>
                <MudItem xs="12" sm="4" md="6" Class="my-n3"/>

        <MudItem xs="12" sm="4" md="6" Class="my-n3" >
            <MudTextField Label="Payable To" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.PayableTo" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.PayableTo)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3" />

        <MudItem xs="12" sm="4" md="6" Class="my-n3">
            <MudTextField Label="Attention To" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.AttentionTo" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.AttentionTo)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3" />

        <MudItem xs="12" sm="6" md="6" Class="mt-n3">
            <MudAutocomplete T="GeoapifySuggestion" Label="Search Address" Clearable Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                             SearchFunc="@Search" Variant="Variant.Outlined" Margin="Margin.Normal"
                             ShowProgressIndicator="true" ProgressIndicatorColor="Color.Inherit"
                             ToStringFunc="@((GeoapifySuggestion e)=> e==null?null : $"{e.FormattedAddress}")"
                             Value="@SelectedValue" ValueChanged="@SelectAddress">
                <ItemDisabledTemplate>
                    <MudText>Not available: @context.ToString()</MudText>
                </ItemDisabledTemplate>
            </MudAutocomplete>
        </MudItem>
        <MudItem xs="12" sm="8" md="6" Class="my-n3" />

        <MudItem xs="12" sm="8" md="6" Class="my-n3">
            <MudTextField Label="Address 1" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.AddressLine1" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.AddressLine1)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3" />

        <MudItem xs="12" sm="8" md="6" Class="my-n3">
            <MudTextField Label="Address 2" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.AddressLine2" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.AddressLine2)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3" />

        <MudItem xs="12" sm="8" md="6" Class="my-n3">
            <MudTextField Label="Address 3" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.AddressLine3" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.AddressLine3)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="6" Class="my-n3" />

        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="City" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.City" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.City)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="State" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.State" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.State)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="my-n3">
            <MudTextField Label="Zip Code" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.ZipCode" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.ZipCode)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4" md="3" Class="my-n3" />

        <MudItem xs="12" sm="8" md="6" Class="my-n3">
            <MudTextField Label="Invoice Prefix" Variant="Variant.Outlined"
                          @bind-Value="@ReimbursementEntity.InvoicePrefix" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.InvoicePrefix)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="8" md="6" Class="my-n3"/>

        <MudItem xs="12" sm="4" md="6" Class="my-n3">
            <MudTextField AutoGrow Label="Comments" Variant="Variant.Outlined"
                          Style="min-height: 55px !important"
                          @bind-Value="@ReimbursementEntity.Comments" Margin="Margin.Normal"
                          For="@(() => ReimbursementEntity.Comments)"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="8" md="6" Class="my-n3" />

        <MudItem xs="12" sm="12" md="12" Class="my-n3">
            <MudDataGrid Dense="true" @ref="dataGrid" T="ReimbursementEntityRCAContact" Items="@ReimbursementEntity.ReimbursementEntityRCAContacts" EditMode="@DataGridEditMode.Cell" ReadOnly="false">
                <ToolBarContent>

                    <MudItem xs="12" sm="12" md="12" Class="d-flex justify-end mb-n10 mr-3">

                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="AddNewContact">Add Contact</MudButton>
                    </MudItem>
                </ToolBarContent>
                <Columns>

                    <PropertyColumn Property="x => x.RCAContactId" Title="RCA Contact" Sortable="false" Filterable="false" Editable>
                        <EditTemplate Context="contactContext">
                            <MudSelect T="Guid" @bind-Value="contactContext.Item.RCAContactId" ToStringFunc="@((Guid id) => GetDisplayText(id))"
                                       Label="" HelperText="" Placeholder="Select Contact"
                                       Variant="Variant.Outlined" Margin="Margin.Normal"
                                       For="@(() => contactContext.Item.RCAContactId)">
                                @foreach (var option in rcaContacts)
                                {
                                    <MudSelectItem T="Guid" Value="@option.RCAContactId">@option.LastName, @option.FirstName</MudSelectItem>
                                }
                            </MudSelect>
                        </EditTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.IsPrimaryContact" Title="Primary" Sortable="false" Filterable="false" Editable>
                        <EditTemplate Context="primaryContext">
                            <MudCheckBox T=bool Value="primaryContext.Item.IsPrimaryContact" ValueChanged="@((isChecked) => CheckPrimaryValue(isChecked, primaryContext.Item))"
                                         For="@(() => primaryContext.Item.IsPrimaryContact)" />
                        </EditTemplate>
                    </PropertyColumn>

                    <TemplateColumn>
                        <EditTemplate Context="deleteContext">
                            <MudStack Row>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(async () => await DeleteContact(deleteContext.Item))" />
                            </MudStack>
                        </EditTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudItem>
    </MudGrid>
</MudContainer>


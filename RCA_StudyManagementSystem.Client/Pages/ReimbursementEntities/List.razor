@page "/reimbursemententities/list"

@using Blazored.LocalStorage
@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using RCA_StudyManagementSystem.Shared.ViewModels
@using MudBlazor
@using System.Linq

@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject ReimbursementEntityData ReimbursementEntityData
@inject GridStateView<ReimbursementEntity> ReimbGridStateView
@inject ILocalStorageService LocalStorage

@implements IDisposable

@rendermode InteractiveWebAssembly


<MudDataGrid T="ReimbursementEntity" @ref="reimbGrid" Items="@_displayItems" SortMode="SortMode.Single" Filterable="true"
             QuickFilter="@_quickFilter" Dense
             FilterDefinitions="@ReimbGridStateView.FilterDefinitions"
             SortDefinitions="@ReimbGridStateView.SortDefinitions"
             CurrentPage="@ReimbGridStateView.CurrentPage"
             CurrentPageChanged=@((currentPage) => OnCurrentPageChanged(currentPage))
             FilterMode="DataGridFilterMode.ColumnFilterRow" AllowUnsorted="false" FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Reimbursement Entities</MudText>
        <MudSpacer />
@*         <MudButton Class="mr-2" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled" OnClick="() => ClearStateItems()">Reset Filters</MudButton>
 *@        <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true" TextUpdateSuppression="false"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable="true"></MudTextField>
    </ToolBarContent>
    <ColGroup>
       
    </ColGroup>
    <Columns>

        <PropertyColumn Property="x => x.Name" Title="Name" Filterable="false" />
        <PropertyColumn Property="x => x.PayableTo" Title="Payable To" Filterable="false" />
        <PropertyColumn Property="x => x.AttentionTo" Title="Attention To" Filterable="false" />
        <PropertyColumn Property="x => x.City" Title="City" Filterable="false" />
               
        <TemplateColumn HeaderText="Actions">
            <CellTemplate>
                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.ContactPage" OnClick=@(() => ViewItem(context.Item, context.Item)) Variant="Variant.Text" Color="Color.Primary">Edit</MudIconButton>
                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" Href="@($"/reimbursemententities/edit/{context.Item.ReimbursementEntityId}")" Variant="Variant.Text" Color="Color.Primary">Edit</MudIconButton>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="ReimbursementEntity" />
    </PagerContent>
</MudDataGrid>
@* <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"  OnClick="OnImport">Import Hospitals</MudButton>
 *@

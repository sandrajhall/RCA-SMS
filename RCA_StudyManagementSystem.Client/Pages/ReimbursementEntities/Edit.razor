@attribute [Authorize]
@page "/app/reimbursemententities/edit/{ReimbursementEntityId:guid}"
@page "/app/reimbursemententities/edit/{ReimbursementEntityId:guid}/{IsSaved:bool?}"
@using Microsoft.AspNetCore.Authorization
@using RCA_StudyManagementSystem.Client.Services
@using RCA_StudyManagementSystem.Shared.Domain
@using System.ComponentModel.DataAnnotations
@using System.Net.Http
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ReimbursementEntityData ReimbursementEntityData
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject ILogger<Edit> Logger
@inject AuthenticationStateProvider AuthStateProvider




@rendermode InteractiveAuto

@* This style does not get picked up in the css file, so it has to go here.
 *@
<style>
    .mud-toolbar {
        --mud-internal-toolbar-height: 15px !important;
        z-index: 10000 !important;
    }
</style>


<MudPaper Class="d-flex pa-2 rca-case-header">
    <h3 class="mt-2 mr-5"></h3>


    <style>
        .rca-case-header {
            background-color: #b0c5dd !important;
        }
    </style>


    <MudSpacer />

        <div class="col-4 mt-1">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Color="Color.Info" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnSubmit">Save</MudButton>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Color="Color.Info" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnSaveAndClose">Save and Close</MudButton>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnDeactivate">Deactivate </MudButton>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Cancel" Color="Color.Warning" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnCancel">Cancel </MudButton>

        </div>


</MudPaper>
<br />


<EditForm Enhance OnSubmit="OnSubmit" FormName="EditReimbursementEntity" EditContext=EditContext>
    <ObjectGraphDataAnnotationsValidator />
        <ValidationSummary />

    @if (IsSaved)
    {
        Snackbar.Add(@SaveMessage, severity);
        IsSaved = false;
    }
    @if (HasErrors)
        {
        Snackbar.Add(@SaveMessage, severity);
        }

    <Fields ReimbursementEntity="@ReimbursementEntity" IsSaved=@IsSaved />

    </EditForm>

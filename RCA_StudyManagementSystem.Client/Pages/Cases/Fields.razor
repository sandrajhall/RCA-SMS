@using RCA_StudyManagementSystem.Shared.Domain
@using RCA_StudyManagementSystem.Client.Services
@using System.ComponentModel.DataAnnotations
@using MudBlazor
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json;
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject LookupData LookupData
@inject StudyLookupData StudyLookupData
@inject StudyHistologyData StudyHistologyData
@inject IDialogService DialogService
@inject IConfiguration Configuration
@inject StudyData StudyData
@inject DoctorData DoctorData
@inject HospitalData HospitalData
@inject PatientData PatientData
@inject DoNotContactData DoNotContactData
@inject UserData UserData




@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@* This style does not get picked up in the css file, so it has to go here.
 *@
<style>
    .mud-toolbar {
        --mud-internal-toolbar-height: 15px !important;
        z-index: 10000 !important;
    }

    .mud-popover {
        z-index: 20000 !important;
    }

    .mud-input > textarea.mud-input-root.mud-input-root-margin-dense {
        padding-left: 8px !important;
    }

    .mud-input {
        background-color: white !important;
    }

    .mud-input-control.mud-input-control-margin-normal.mud-input-outlined-with-label {
        font: caption;
        font-weight: bolder !important;
    }

    .mud-grid {
        background-color: @StudyColor !important;
        padding-right: 24px;
        padding-bottom: 24px;
    }

    .mud-checkbox-false {
        background-color: white !important;
    }

</style>

<NavigationLock OnBeforeInternalNavigation="HandleInternalNavigation" ConfirmExternalNavigation="EditContext.IsModified()" />


@if (IsSaved)
{

    Snackbar.Add("Case has been saved.", Severity.Success);
    IsSaved = false;

}
<MudTabs KeepPanelsAlive="true" Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Demographics" Icon="@Icons.Material.Filled.Person">
        <MudGrid Class="mt-3 ml-1" Style="width: 100%; margin: 0;">
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudTextField T="string" Mask="@(new PatternMask("000-00-0000"))" Label="SSN" Variant="Variant.Outlined"
                              Value="@Patient.SocialSecurityNumber" Margin="Margin.Normal" ValueChanged="(value) => CheckSSN(value)"
                              For="@(() => Patient.SocialSecurityNumber)"></MudTextField>
                <MudText Color="Color.Info">@errorMsgSSN</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudTextField T="DateTime?" Mask="@(new DateMask("MM/dd/yyyy"))" HelperText="MM/dd/yyyy" Label="DOB" Variant="Variant.Outlined"
                              Value="@Patient.DateOfBirth" Margin="Margin.Normal" ValueChanged="(value) => CheckDOB(value)"
                              For="@(() => Patient.DateOfBirth)"
                              OnlyValidateIfDirty="true"></MudTextField>
                <MudText Color="Color.Info">@errorMsgDOB</MudText>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" Class="my-n3" />


            <MudSpacer />
            @*             <MudItem xs="4" sm="3" md="1" Class="my-n3">
                <MudCheckBox T=bool Label="Hold" @bind-Value="Patient.IsOnHold" For="@(() => Patient.IsOnHold)"  />
            </MudItem> *@
            <MudItem xs="12" sm="4" md="3" Class="my-n3">
                <MudTextField T="string" Label="First Name" Variant="Variant.Outlined"
                              Value="@Patient.FirstName" Margin="Margin.Normal"
                              ValueChanged="(value) => OnFirstNameChanged(value)"
                              For="@(() => Patient.FirstName)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="4" md="3" Class="my-n3">
                <MudTextField Label="Middle Name" Variant="Variant.Outlined"
                              @bind-Value="@Patient.MiddleName" Margin="Margin.Normal"
                              For="@(() => Patient.MiddleName)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="4" md="3" Class="my-n3">
                <MudTextField T="string" Label="Last Name" Variant="Variant.Outlined"
                              Value="@Patient.LastName" Margin="Margin.Normal"
                              ValueChanged="(value) => OnLastNameChanged(value)"
                              For="@(() => Patient.LastName)"></MudTextField>
                <MudText Color="Color.Info">@errorMsgName</MudText>
            </MudItem>
            <MudItem xs="4" sm="3" md="2" Class="my-n3">
                <MudSelect T="string" Value="Patient.Suffix" ValueChanged="(string value) => OnSuffixChanged(value)"
                           Label="Suffix" HelperText="" Placeholder="Select Suffix" Clearable OnClearButtonClick="() => OnSuffixCleared()"
                           Variant="Variant.Outlined" Margin="Margin.Normal"
                           For="@(() => Patient.Suffix)">
                    <MudSelectItem Value="@("Jr.")">Jr.</MudSelectItem>
                    <MudSelectItem Value="@("Sr.")">Sr.</MudSelectItem>
                    <MudSelectItem Value="@("III")">III</MudSelectItem>
                    <MudSelectItem Value="@("IV")">IV</MudSelectItem>
                    <MudSelectItem Value="@("V")">V</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="3" Class="my-n3">
                <MudTextField Label="Preferred Name" Variant="Variant.Outlined"
                              @bind-Value="@Patient.PreferredName" Margin="Margin.Normal"
                              For="@(() => Patient.PreferredName)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="4" md="3" Class="my-n3">
                <MudTextField Label="Email" Variant="Variant.Outlined"
                              @bind-Value="@Patient.Email" Margin="Margin.Normal"
                              For="@(() => Patient.Email)"></MudTextField>
            </MudItem>

            <MudItem xs="12" sm="6" md="6" Class="mt-n3" />

            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudSelect Value="Patient.Gender" ValueChanged="(string value) => OnGenderChanged(value)"
                           Label="Gender" HelperText="" Placeholder="Select Gender"
                           Variant="Variant.Outlined" Margin="Margin.Normal"
                           For="@(() => Patient.Gender)">
                    @foreach (var option in GenderList)
                    {
                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudSelect Value="Patient.Race" ValueChanged="(string value) => OnRaceChanged(value)"
                           Label="Race" HelperText="" Placeholder="Select Race"
                           Variant="Variant.Outlined" Margin="Margin.Normal"
                           For="@(() => Patient.Race)">
                    @foreach (var option in RaceList)
                    {
                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="6" Class="my-n3">
                <MudSelect Value="Patient.Ethnicity" ValueChanged="(string value) => OnEthnicityChanged(value)"
                           Label="Ethnicity" HelperText="" Placeholder="Select Ethnicity"
                           Variant="Variant.Outlined" Margin="Margin.Normal"
                           For="@(() => Patient.Ethnicity)">
                    @foreach (var option in EthnicityList)
                    {
                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="6" Class="mt-n3">
                <MudAutocomplete T="GeoapifySuggestion" Label="Search Address" Clearable Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                 SearchFunc="@Search" Variant="Variant.Outlined" Margin="Margin.Normal"
                                 ShowProgressIndicator="true" ProgressIndicatorColor="Color.Inherit"
                                 ToStringFunc="@((GeoapifySuggestion e)=> e==null?null : $"{e.FormattedAddress}")"
                                 Value="@SelectedValue" ValueChanged="@SelectAddress">
                    <ItemDisabledTemplate>
                        <MudText>Not available: @context.ToString()</MudText>
                    </ItemDisabledTemplate>
                </MudAutocomplete>
            </MudItem>
            <MudItem xs="12" sm="8" md="6" Class="my-n3" />

            <MudItem xs="12" sm="8" md="6" Class="my-n3">
                <MudTextField Label="Address 1" Variant="Variant.Outlined"
                              @bind-Value="@Patient.Address1" Margin="Margin.Normal"
                              For="@(() => Patient.Address1)"></MudTextField>
            </MudItem>

            <MudItem xs="12" sm="8" md="6" Class="my-n3">
                <MudTextField Label="Address 2" Variant="Variant.Outlined"
                              @bind-Value="@Patient.Address2" Margin="Margin.Normal"
                              For="@(() => Patient.Address2)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudTextField Label="City" Variant="Variant.Outlined"
                              @bind-Value="@Patient.City" Margin="Margin.Normal"
                              For="@(() => Patient.City)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudTextField Label="State" Variant="Variant.Outlined"
                              @bind-Value="@Patient.State" Margin="Margin.Normal"
                              For="@(() => Patient.State)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudTextField Label="Zip Code" Variant="Variant.Outlined"
                              @bind-Value="@Patient.ZipCode" Margin="Margin.Normal"
                              For="@(() => Patient.ZipCode)"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="my-n3">
                <MudSelect Value="Patient.County" ValueChanged="(string value) => OnCountyChanged(value)"
                           Label="County" HelperText="" Placeholder="Select County" TextChanged="OnCountyChanged"
                           Variant="Variant.Outlined" Dense Margin="Margin.Normal"
                           For="@(() => Patient.County)">
                    @foreach (var option in CountyList)
                    {
                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                    }
                </MudSelect>
                <MudText Color="Color.Info">@errorMsgCounty</MudText>
            </MudItem>


            <MudItem xs="12" sm="12" md="12" Class="my-n3">
                <MudDataGrid Dense="true" @ref="dataGrid" T="PatientPhoneNumber" Items="@Patient.PatientPhoneNumbers" EditMode="@DataGridEditMode.Cell" ReadOnly="false">
                    <ToolBarContent>

                        <MudItem xs="12" sm="12" md="12" Class="d-flex justify-end mb-n10 mr-3">

                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="AddNewPhoneNumber">Add Phone</MudButton>
                        </MudItem>
                    </ToolBarContent>
                    <Columns>

                        <PropertyColumn Property="x => x.PhoneNumber" Title="Phone Number" Sortable="false" Filterable="false" Editable>
                            <EditTemplate Context="phoneContext">
                                <MudTextField T="string" class="mud-text-field-input" @bind-Value="phoneContext.Item.PhoneNumber"
                                              Variant="Variant.Outlined"
                                              Mask="@(new PatternMask("000-000-0000"))" Margin="Margin.Normal"
                                              For="@(() => phoneContext.Item.PhoneNumber)" Style="border: 1px solid #ccc; border-radius: 4px;"></MudTextField>
                            </EditTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.PhoneType" Title="Type" Sortable="false" Filterable="false" Editable="true">
                            <EditTemplate Context="typeContext">
                                <MudSelect T="string" class="mud-select-input" @bind-Value="typeContext.Item.PhoneType"
                                           Placeholder="Select Type" Margin="@Margin.Normal" Variant="Variant.Outlined"
                                           Style="border: 1px solid #ccc; border-radius: 4px; z-index: 2000;"
                                           For="@(() => typeContext.Item.PhoneType)">
                                    <MudSelectItem Value="@("Home")">Home</MudSelectItem>
                                    <MudSelectItem Value="@("Mobile")">Mobile</MudSelectItem>
                                    <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                                </MudSelect>
                            </EditTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.PhoneNumberComments" Required="false" Title="Comments" Sortable="false" Filterable="false">
                            <EditTemplate Context="commentsContext">
                                <MudTextField T="string" AutoGrow class="mud-text-field-input" @bind-Value="commentsContext.Item.PhoneNumberComments"
                                              Margin="Margin.Normal" Variant="Variant.Text"
                                              Style="border: 1px solid #ccc; border-radius: 4px; min-height: 55px !important"
                                              For="@(() => commentsContext.Item.PhoneNumberComments)">
                                </MudTextField>
                            </EditTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.IsPrimary" Title="Primary" Sortable="false" Filterable="false">
                            <EditTemplate Context="primaryContext">
                                <MudCheckBox T=bool Value="primaryContext.Item.IsPrimary" ValueChanged="@((isChecked) => CheckPrimaryValue(isChecked, primaryContext.Item))"
                                             For="@(() => primaryContext.Item.IsPrimary)" />
                            </EditTemplate>
                        </PropertyColumn>

                        <TemplateColumn>
                            <EditTemplate Context="deleteContext">
                                <MudStack Row>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(async () => await DeletePhoneNumber(deleteContext.Item))" />
                                </MudStack>
                            </EditTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudText Color="Color.Success">Phone records last modified on @modDatePhone by @modUserPhone</MudText>
                    </PagerContent>
                </MudDataGrid>
            </MudItem>
            <MudItem xs="12" sm="12" md="6" Class="my-n3">
                <MudTextField Label="Patient Comments" AutoGrow Variant="Variant.Outlined"
                              @bind-Value="@Patient.PatientComments" Margin="Margin.Normal" Style="min-height: 55px !important"
                              For="@(() => Patient.PatientComments)"></MudTextField>
            </MudItem>
            <MudItem xs="0" sm="6" md="6" Class="my-n3" />
        </MudGrid>
        <MudText Color="Color.Success">Patient record last modified on @modDate by @modUser.</MudText>

    </MudTabPanel>


    <MudTabPanel Text="Path Report(s)" Icon="@Icons.Material.Filled.NoteAlt">
        <MudGrid Class="mt-3 ml-1">
            <MudItem xs="12" sm="12" md="12" Class="d-flex justify-end my-n3">
                @if (!string.IsNullOrEmpty(Study.PathMaxNum))
                {
                    if (Patient.PathReports.Count < Int32.Parse(Study.PathMaxNum))
                    {
                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="AddNewPathReport">Add Path Report</MudButton>
                    }
                }
                else
                {
                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="AddNewPathReport">Add Path Report</MudButton>
                }
            </MudItem>
            <MudItem xs="12" sm="12" md="12" Class="my-n3">

                <MudExpansionPanels MultiExpansion="true">

                    @foreach (var pathReport in Patient.PathReports)
                    {
                        var pathHeader = "Path Report " + pathReport.PathIndex.ToString() + " - Export Date: " + pathReport.RcaExportDate?.ToShortDateString();

                        <div @key="pathReport.PathReportId">
                        <MudExpansionPanel Text="@pathHeader" Expanded="true">
                            <MudGrid>

                                <MudItem xs="12" sm="12" md="3" Class="mb-3 mt-2">
                                    <MudAutocomplete T="Hospital" Value="pathReport.HospitalEntity" @ref="@hospAutocompleteRef"
                                                     SearchFunc="HospitalSearch"
                                                     @onfocus="@(() => _activeReport = pathReport)"
                                                     SelectValueOnTab="true"
                                                     DebounceInterval="300"
                                                     Immediate="true"
                                                     MinCharacters="3"
                                                     ResetValueOnEmptyText="false"
                                                     MaxItems="50"
                                                     Label="Submitting Hospital"
                                                     Placeholder="Search for Hospital"
                                                     Modal="true" 
                                                     Clearable 
                                                     OnClearButtonClick="() => OnHospitalCleared(pathReport)"
                                                     Variant="Variant.Outlined"
                                                     ValueChanged="((value) => OnHospitalSelectionChanged(value, pathReport))"
                                                     ToStringFunc="@(item => item == null ? string.Empty : $"{item.HospitalName}")"
                                                     ShowProgressIndicator="true"
                                                     ProgressIndicatorColor="Color.Info"
                                                     AnchorOrigin="@_anchor"
                                                     TransformOrigin="@_transform"
                                                     RelativeWidth="_dropdownWidth">
                                                     <ItemTemplate Context="item">
                                                        <div class="d-flex flex-column">
                                                            <MudText Typo="Typo.body1">@item.HospitalName</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Info">
                                                                @item.City
                                                            </MudText>
                                                        </div>
                                                    </ItemTemplate>
                                     </MudAutocomplete>
                                </MudItem>
                                <MudItem xs="12" sm="12" md="1" Class="mt-7">
                                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Medium"
                                               ButtonType="ButtonType.Button" OnClick="() => EditHospital(pathReport)"></MudButton>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="2" Class="mb-n3">
                                    <MudTextField Label="Sub. Hosp. Path Report Number" Variant="Variant.Outlined"
                                                  @bind-Value="@pathReport.SubmittingHospitalPathReportNumber" Margin="Margin.Normal"
                                                  For="@(() => pathReport.SubmittingHospitalPathReportNumber)"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="2" Class="mb-n3">
                                    <MudDatePicker Label="Date of Procedure" Editable="true" Placeholder="Select Date" Date="pathReport.DateOfProcedure"
                                                   Variant="Variant.Outlined" Margin="Margin.Normal" Mask="@(new DateMask("MM/dd/yyyy"))" DateFormat="MM/dd/yyyy"
                                                   For="@(() => pathReport.DateOfProcedure)"
                                                   DateChanged="@((Date) => CalculateAgeAtProcedure(Patient, pathReport, Date, Patient.DateOfBirth))" />
                                    <MudText Color="Color.Info">@errorMsgPath</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="3" md="1" Class="mb-n3">
                                    <MudTextField T="string" Label="Age at Procedure" Variant="Variant.Outlined"
                                                  @bind-Value="@pathReport.AgeAtProcedure" Margin="Margin.Normal"></MudTextField>
                                    <MudText Color="Color.Info">@errorMsgAge</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="2" Class="mb-n3">
                                    <MudSelect @ref="exportSelect" @bind-Value="@pathReport.ExportStatus" Label="Export Status" HelperText="" Placeholder=""
                                               Variant="Variant.Outlined" Margin="Margin.Normal"
                                               For="@(() => pathReport.ExportStatus)">
                                        <MudSelectItem Value="@("Ready")">Ready</MudSelectItem>
                                        <MudSelectItem Value="@("Exported")">Exported</MudSelectItem>
                                        <MudSelectItem Value="@("Ineligible for export")">Ineligible for export</MudSelectItem>
                                        <MudSelectItem Value="@("Path too early")">Path too early</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="3" md="1" Class="mb-n3 d-flex justify-end">
                                    <MudCheckBox T=bool Label="Hold" Value="pathReport.IsOnHold" For="@(() => pathReport.IsOnHold)"
                                                 ValueChanged="@((value) => OnIsOnHoldChangedAsync(pathReport, value))" Dense />
                                </MudItem>

                                @if (Patient.StudyId == Guid.Parse("631B71B4-B451-4FD7-8B82-08DDD0513E23")) // Endometrial Study CECS
                                {
                                    <MudItem xs="12" sm="3" md="1" Class="mb-n3 d-flex">
                                        <MudCheckBox T=bool Label="Addendum" @bind-Value="pathReport.IsAddendum" 
                                                        For="@(() => pathReport.IsAddendum)"
                                                        Dense />
                                    </MudItem>
                                }

                                <MudItem xs="4" sm="3" md="2" Class="mb-n3">
                                    <MudSelect T="string" Label="Slides" @bind-Value="pathReport.SlidesResideAtSubmittingHospital" HelperText="Slides reside at submitting Hospital?"
                                               Placeholder="" Variant="Variant.Outlined" Margin="Margin.Normal"
                                               For="@(() => pathReport.SlidesResideAtSubmittingHospital)">
                                        <MudSelectItem Value="@("Yes")">Yes</MudSelectItem>
                                        <MudSelectItem Value="@("No")">No</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                @if (pathReport.SlidesResideAtSubmittingHospital == "Yes")
                                {
                                    <MudSpacer />
                                    <MudItem xs="0" sm="0" md="9" Class="my-n3" />
                                }

                                @if (pathReport.SlidesResideAtSubmittingHospital == "No")
                                {
                                    <MudItem xs="12" sm="12" md="3" Class="mb-3 mt-2">
                                        <MudAutocomplete T="Hospital" Value="pathReport.OrigHospitalEntity" @ref="@origHospAutocompleteRef"
                                                         SearchFunc="OrigHospitalSearch"
                                                         SelectValueOnTab="true"
                                                         DebounceInterval="300"
                                                         Immediate="true"
                                                         MinCharacters="3"
                                                         ResetValueOnEmptyText="false"
                                                         MaxItems="50"
                                                         Label="Originating Hospital"
                                                         Placeholder="Search for Hospital"
                                                         Modal="true" Clearable CoerceValue="false"
                                                         OnClearButtonClick="() => OnOrigHospitalCleared(pathReport)"
                                                         Variant="Variant.Outlined"
                                                         ValueChanged="((value) => OnOrigHospitalSelectionChanged(value, pathReport))"
                                                         ToStringFunc="@(item => item == null ? string.Empty : $"{item.HospitalName}")"
                                                         ShowProgressIndicator="true"
                                                         ProgressIndicatorColor="Color.Info"
                                                         AnchorOrigin="@_anchor"
                                                         TransformOrigin="@_transform"
                                                             RelativeWidth="_dropdownWidth">
                                                <ItemTemplate Context="item">
                                                    <div class="d-flex flex-column">
                                                        <MudText Typo="Typo.body1">@item.HospitalName</MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Info">
                                                            @item.City
                                                        </MudText>
                                                    </div>
                                                </ItemTemplate>
                                            </MudAutocomplete>
                                    </MudItem>
                                    <MudItem xs="12" sm="12" md="1" Class="mt-7">
                                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Medium"
                                                   ButtonType="ButtonType.Button" OnClick="() => EditOrigHospital(pathReport)"></MudButton>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="2" Class="mb-n3">
                                        <MudTextField Label="Orig. Hosp. Path Report Number" Variant="Variant.Outlined"
                                                      @bind-Value="@pathReport.OriginatingHospitalPathReportNumber" Margin="Margin.Normal"
                                                      For="@(() => pathReport.OriginatingHospitalPathReportNumber)"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="12" sm="12" md="2" Class="mb-n1">
                                        <MudTextField Label="Originating Facility Comments" AutoGrow style="min-height: 55px !important" Variant="Variant.Outlined"
                                                      @bind-Value="@pathReport.OriginatingHospitalComments" Margin="Margin.Normal"
                                                      For="@(() => pathReport.OriginatingHospitalComments)"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="12" sm="3" md="1" Class="mb-n3 d-flex">
                                        <MudCheckBox T=bool Label="Path Report Obtained" @bind-Value="pathReport.PathReportObtained"
                                                     For="@(() => pathReport.PathReportObtained)"
                                                     Dense />
                                    </MudItem>
                                }
                                <MudItem xs="12" sm="12" md="5" Class="mb-3 mt-2">
                                    <MudAutocomplete T="Hospital" Value="pathReport.Reimb1HospitalEntity" @ref="@reimb1AutocompleteRef"
                                                     SearchFunc="Reimb1HospitalSearch"
                                                     SelectValueOnTab="true"
                                                     DebounceInterval="300"
                                                     Immediate="true"
                                                     MinCharacters="3"
                                                     ResetValueOnEmptyText="false"
                                                     MaxItems="50"
                                                     Label="Reimbursement 1"
                                                     Placeholder="Search for Hospital"
                                                     Modal="true" Clearable CoerceValue="false"
                                                     OnClearButtonClick="() => OnReimbursement1Cleared(pathReport)"
                                                     Variant="Variant.Outlined"
                                                     ValueChanged="((value) => OnReimbursement1SelectionChanged(value, pathReport))"
                                                     ToStringFunc="@(item => item == null ? string.Empty : $"{item.HospitalName}")"
                                                     ShowProgressIndicator="true"
                                                     ProgressIndicatorColor="Color.Info"
                                                     AnchorOrigin="@_anchor"
                                                     TransformOrigin="@_transform"
                                                         RelativeWidth="_dropdownWidth">
                                            <ItemTemplate Context="item">
                                                <div class="d-flex flex-column">
                                                    <MudText Typo="Typo.body1">@item.HospitalName</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Info">
                                                        @item.City
                                                    </MudText>
                                                </div>
                                            </ItemTemplate>
                                        </MudAutocomplete>
                                </MudItem>
                                <MudItem xs="12" sm="12" md="5" Class="mb-3 mt-2">

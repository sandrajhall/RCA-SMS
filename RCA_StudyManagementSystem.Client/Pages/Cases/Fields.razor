                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(async () => DeletePathReport(pathReport))" />
                            </MudItem>
                        </MudExpansionPanel>
                                <MudText Color="Color.Success">Path records last modified on @modDatePath by @modUserPath.</MudText>

                        </div>
                    }

                </MudExpansionPanels>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
</MudTabs>

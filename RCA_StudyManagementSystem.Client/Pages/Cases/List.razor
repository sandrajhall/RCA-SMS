            <PropertyColumn Property="x => x.DateOfBirth.Value.ToShortDateString()" Title="Date of Birth" Filterable="false" />

            <PropertyColumn Property="x => x.SocialSecurityNumber" Title="Social Security Number" Filterable="false" />

            <PropertyColumn Property="x => x.DisplayName" Title="Display Name" Hidden Filterable="false" />

            <PropertyColumn Property="x => x.StudyName" Title="Study" Filterable="false" CellStyle="max-width: 150px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">
                <FilterHeaderCell>
                    <FilterOptions>
                        <MudDataGridFilterOperator Operator="FilterOperator.String.Contains" />

@attribute [Authorize]
@page "/app/cases/create"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using RCA_StudyManagementSystem.Client.Services
@using RCA_StudyManagementSystem.Client.Utilities
@using RCA_StudyManagementSystem.Shared.Domain
@using System.ComponentModel.DataAnnotations
@using System.Net.Http
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject PatientData PatientData
@inject HospitalData HospitalData
@inject DoctorData DoctorData
@inject ISnackbar Snackbar
@inject ILogger<Create> Logger
@inject StudyData StudyData
@inject GenerateCaseNumber GenerateCaseNumber


@rendermode InteractiveAuto

@* This style does not get picked up in the css file, so it has to go here.
 *@
<style>
    .mud-toolbar {
        --mud-internal-toolbar-height: 15px !important;
        z-index: 10000 !important;
    }
</style>

<MudPaper Class="d-flex pa-2 rca-case-header">
    <h3 class="mt-2 mr-5">New Case</h3>
    <MudItem xs="4" sm="3" md="2">
        <MudSelect id="studySelect" T="Study" @bind-Value="studySelectValue" Typo="Typo.subtitle1" Margin="Margin.Dense" 
        Label="Study" HelperText="" Placeholder="Select Study" Variant="Variant.Outlined" Dense="true"
                   SelectedValuesChanged="@((value) => OnStudySelectChanged(value.First<Study>()))"
        aria-hidden="false">
            @foreach (var option in StudyList)
            {
                <MudSelectItem T="Study" Value="@option">@option.Prefix</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <style>
        .rca-case-header {
            background-color: @StudyColor;
        }
    </style>


    <MudSpacer />
    <div class="mt-3">
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Color="Color.Info" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnSubmit">Save</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Color="Color.Info" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnSaveAndAddNew">Save and Add New</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Color="Color.Info" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnSaveAndClose">Save and Close</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Cancel" Color="Color.Warning" Size="Size.Small" ButtonType="ButtonType.Submit" OnClick="OnCancel">Cancel</MudButton>
        @*             <button type="submit" class="btn btn-outline-primary ms-1">Submit</button>
        *@
    </div>
</MudPaper>
<br />


<EditForm OnSubmit="OnSubmit" Enhance FormName="CreateCase" EditContext="EditContext">
    <ObjectGraphDataAnnotationsValidator />
    <ValidationSummary />
    @if (IsSaved)
    {
        Snackbar.Add("Case has been created.", Severity.Success);
        IsSaved = false;
    }
    @if (HasErrors)
    {
        Snackbar.Add(@SaveMessage, severity);

    }

    @if (StudyId != Guid.Empty)
    {
        <div class="@(ShowFields ? "" : "d-none")">
            <Fields Patient="@Patient" StudyId=@StudyId
                    @bind-StudyColor="StudyColor" />
        </div>
    }



</EditForm>

